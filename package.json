{
  "name": "carvd-studio-monorepo",
  "description": "Carvd Studio - Professional furniture and cabinetry design software (monorepo)",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=@carvd/desktop",
    "dev:website": "npm run dev --workspace=@carvd/website",
    "build:desktop": "npm run build --workspace=@carvd/desktop",
    "build:website": "npm run build --workspace=@carvd/website",
    "package:desktop": "npm run package --workspace=@carvd/desktop",
    "package:mac": "npm run package:mac --workspace=@carvd/desktop",
    "package:mac:dmg": "npm run package:mac:dmg --workspace=@carvd/desktop",
    "package:mac:x64": "npm run package:mac:x64 --workspace=@carvd/desktop",
    "package:mac:universal": "npm run package:mac:universal --workspace=@carvd/desktop",
    "package:win": "npm run package:win --workspace=@carvd/desktop",
    "deploy:website": "cd packages/website && vercel --prod",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "generate-keys": "npm run generate-keys --workspace=@carvd/desktop",
    "generate-test-license": "npm run generate-test-license --workspace=@carvd/desktop",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/out packages/desktop/dist packages/desktop/out",
    "fresh-install": "npm run clean && npm install",
    "prepare": "husky || true"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:mdbaldwin1/carvd-studio.git"
  },
  "author": "Michael Baldwin",
  "license": "ISC",
  "overrides": {
    "@eslint/config-array": {
      "minimatch": "3.1.5"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.5"
    },
    "@malept/flatpak-bundler": {
      "lodash": "4.18.1"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    },
    "@xmldom/xmldom": "0.8.12",
    "app-builder-lib": {
      "minimatch": "10.2.3"
    },
    "electron-winstaller": {
      "lodash": "4.18.1"
    },
    "eslint": {
      "minimatch": "3.1.5"
    },
    "eslint-plugin-react": {
      "minimatch": "3.1.3"
    },
    "filelist": {
      "minimatch": "5.1.8"
    },
    "glob": {
      "minimatch": "3.1.5"
    },
    "jsdom": {
      "undici": "7.24.0"
    },
    "jspdf": {
      "dompurify": "3.3.2"
    },
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tar": "7.5.13",
    "vitest-axe": {
      "lodash-es": "4.18.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --check"
    ],
    "*.{json,css,md}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "vite": "^8.0.5"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.31.1",
    "lightningcss-darwin-x64": "^1.31.1"
  }
}
